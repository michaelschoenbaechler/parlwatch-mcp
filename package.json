{
  "name": "parlwatch-mcp",
  "version": "0.0.1",
  "description": "Swiss parliament MCP server and UI widgets monorepo",
  "private": true,
  "type": "module",
  "main": "packages/server/dist/index.js",
  "types": "packages/server/dist/index.d.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:ui": "npm run build -w @parlwatch/ui",
    "build:shared": "npm run build -w @parlwatch/shared",
    "build:server": "npm run build -w @parlwatch/server",
    "dev:ui": "npm run dev -w @parlwatch/ui",
    "dev:server": "npm run dev -w @parlwatch/server",
    "build": "npm run build:ui && npm run build:shared && npm run build:server",
    "dev": "npm run dev:ui & npm run dev:server",
    "start": "node packages/server/dist/index.js",
    "clean": "rm -rf dist packages/*/dist",
    "type-check:ui": "tsc --noEmit -p packages/ui/tsconfig.json",
    "type-check": "tsc -b && npm run type-check:ui",
    "lint": "eslint \"packages/server/src/**/*.ts\" \"packages/shared/src/**/*.ts\" \"packages/ui/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"packages/server/src/**/*.ts\" \"packages/shared/src/**/*.ts\" \"packages/ui/src/**/*.{ts,tsx}\"",
    "prettier:fix": "prettier --write \"packages/**/*.{ts,tsx}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.0",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelschoenbaechler/parlwatch-mcp.git"
  },
  "keywords": [
    "parlwatch",
    "swiss-parliament",
    "mcp",
    "widgets"
  ],
  "author": "Michael Schönbächler",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/michaelschoenbaechler/parlwatch-mcp/issues"
  },
  "homepage": "https://github.com/michaelschoenbaechler/parlwatch-mcp#readme"
}
